# pnpm config for the whole workspace.
#
# React Native / Metro can't follow pnpm's default isolated (symlinked)
# node_modules layout — transitive deps like babel-preset-expo (a dep of expo)
# end up stranded in the .pnpm store and unresolvable from apps/mobile. A
# hoisted (npm-style) flat layout surfaces them so the bundler resolves them.
#
# This MUST live at the workspace root (not apps/mobile/.npmrc): pnpm only reads
# .npmrc from the cwd upward, so a root install ignores the mobile app's .npmrc.
# Putting it here also means the deps-status re-verify that pnpm runs before
# `pnpm --filter ... build` recreates node_modules with the hoisted layout
# instead of reverting to the isolated one (which broke the CI release build).
node-linker=hoisted
shamefully-hoist=true