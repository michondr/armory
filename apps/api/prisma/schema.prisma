// Phase 0 schema: users, settings, auth. Inventory/sessions/targets land in later phases.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

enum AngularUnit {
  MRAD
  MOA
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  passwordHash String
  displayName  String?
  unitSystem   UnitSystem  @default(METRIC)
  angularUnit  AngularUnit @default(MRAD)

  // Per-user SMTP for notifications. Password stored encrypted at rest (AES-256-GCM).
  smtpHost    String?
  smtpPort    Int?
  smtpUser    String?
  smtpPassEnc String?
  smtpFrom    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens    RefreshToken[]
  guns             Gun[]
  ammo             Ammo[]
  sessions         Session[]
  cartridges       Cartridge[]
  ammoImages       AmmoImage[]
  ammoPriceEntries AmmoPriceEntry[]
  shootingSets     ShootingSet[]
  targets          Target[]
  shots            Shot[]
  scopeProfiles    ScopeProfile[]
  devices          Device[]

  @@map("users")
}

// A user-managed list of cartridge/caliber names. Guns and ammo pick their
// caliber from this list so they match exactly (used to filter ammo by gun).
model Cartridge {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, updatedAt])
  @@map("cartridges")
}

enum BcModel {
  G1
  G7
}

// A firearm owned by a user. Round count starts at initialRoundCount and grows as
// sessions are logged (Phase 2); cleaning is tracked against total rounds fired.
model Gun {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @db.Uuid
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String
  caliber                String?
  purchasePrice          Decimal?  @db.Decimal(12, 2)
  purchaseDate           DateTime?
  initialRoundCount      Int       @default(0)
  cleaningIntervalRounds Int?
  lastCleanedAtRound     Int       @default(0)
  imagePath              String?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  sessions      Session[]
  scopeProfiles ScopeProfile[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@map("guns")
}

// A type of ammunition. Physical quantities stored in SI (grams, m/s); displayed in
// the user's chosen units. Search is case-insensitive over name/caliber/notes.
model Ammo {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @db.Uuid
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  caliber              String?
  bulletWeightG        Float?
  muzzleVelocityMps    Float?
  ballisticCoefficient Float?
  bcModel              BcModel?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  images       AmmoImage[]
  priceEntries AmmoPriceEntry[]
  sessions     Session[]

  @@index([userId])
  @@index([userId, updatedAt])
  @@map("ammo")
}

model AmmoImage {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ammoId    String    @db.Uuid
  ammo      Ammo      @relation(fields: [ammoId], references: [id], onDelete: Cascade)
  imagePath String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ammoId])
  @@index([userId, updatedAt])
  @@map("ammo_images")
}

// A purchase record: price per round can vary across buys, so we keep a log.
model AmmoPriceEntry {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ammoId        String    @db.Uuid
  ammo          Ammo      @relation(fields: [ammoId], references: [id], onDelete: Cascade)
  date          DateTime
  pricePerRound Decimal   @db.Decimal(12, 4)
  currency      String    @default("CZK")
  quantity      Int       @default(1)
  vendor        String?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([ammoId])
  @@index([userId, updatedAt])
  @@map("ammo_price_entries")
}

enum Discipline {
  SHORT
  LONG
}

enum ScoringSystem {
  RINGS
  IPSC
  GROUP
}

enum TargetStatus {
  PENDING
  SCORED
  APPROVED
  MANUAL
}

enum ShotSource {
  AI
  MANUAL
}

// A range visit: one gun + optional ammo, a place + time, and one or more sets.
model Session {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  gunId        String     @db.Uuid
  gun          Gun        @relation(fields: [gunId], references: [id])
  ammoId       String?    @db.Uuid
  ammo         Ammo?      @relation(fields: [ammoId], references: [id])
  startedAt    DateTime   @default(now())
  locationName String?
  latitude     Float?
  longitude    Float?
  discipline   Discipline @default(SHORT)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  sets ShootingSet[]

  @@index([userId])
  @@index([gunId])
  @@index([userId, updatedAt])
  @@map("sessions")
}

// A string of fire at a given distance. IPSC time is captured here (used in Phase 5).
// userId is denormalized onto sets/targets/shots so sync queries stay flat per table.
model ShootingSet {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String    @db.Uuid
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order           Int       @default(0)
  distanceM       Float?
  ipscTimeSeconds Float?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  targets Target[]

  @@index([sessionId])
  @@index([userId, updatedAt])
  @@map("shooting_sets")
}

// One physical target. Manual scoring stores ring values per shot; vision (Phase 3)
// will add x/y positions. totalScore is recomputed whenever shots change.
model Target {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @db.Uuid
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  setId           String        @db.Uuid
  set             ShootingSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  imagePath       String?
  shotCount       Int           @default(0)
  scoringSystem   ScoringSystem @default(RINGS)
  maxScorePerShot Int?
  status          TargetStatus  @default(PENDING)
  totalScore      Float?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  shots Shot[]

  @@index([setId])
  @@index([userId, updatedAt])
  @@map("targets")
}

model Shot {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetId  String     @db.Uuid
  target    Target     @relation(fields: [targetId], references: [id], onDelete: Cascade)
  index     Int        @default(0)
  ringValue Float?
  x         Float?
  y         Float?
  zone      String?
  source    ShotSource @default(MANUAL)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  @@index([targetId])
  @@index([userId, updatedAt])
  @@map("shots")
}

// A scope/optic mounted on a gun: click value + zero, used by the ballistics
// calculator (web + mobile) to turn drop/windage into clicks.
model ScopeProfile {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  gunId         String      @db.Uuid
  gun           Gun         @relation(fields: [gunId], references: [id], onDelete: Cascade)
  name          String
  clickValue    Float       @default(0.1) // in angularUnit per click (e.g. 0.1 MRAD, 0.25 MOA)
  angularUnit   AngularUnit @default(MRAD)
  zeroRangeM    Float       @default(100)
  sightHeightMm Float       @default(50)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  @@index([gunId])
  @@index([userId, updatedAt])
  @@map("scope_profiles")
}

// A mobile device that syncs against this account (bookkeeping + sync diagnostics).
model Device {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  platform   String?
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@map("devices")
}

// Hashed, per-device refresh tokens so we can rotate + revoke individually.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}
